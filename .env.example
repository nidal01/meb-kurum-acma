# Canlı site adresi (canonical, Open Graph, sitemap, robots)
NEXT_PUBLIC_SITE_URL=https://meboyunevi.com

# Google Search Console doğrulama (isteğe bağlı)
# GOOGLE_SITE_VERIFICATION=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Google Gemini — https://aistudio.google.com/apikey (ücretsiz kota)
GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.5-flash-lite

# Supabase — blog taslakları ve yayın (Vercel'de dosyaya yazılamaz)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Admin panel — ilk girişte süper admin oluşturulur
ADMIN_EMAIL=admin@meboyunevi.com
ADMIN_PASSWORD=

# Oturum imzalama (openssl rand -base64 32)
SESSION_SECRET=

# Vercel Cron — Authorization: Bearer <CRON_SECRET>
CRON_SECRET=

# true ise cron taslağı otomatik yayınlar (önerilmez: false)
BLOG_AUTO_PUBLISH=false

# Blog görselleri: auto (Pexels varsa stok, yoksa AI) | pexels | ai | local
# BLOG_IMAGE_PROVIDER=auto
# Pexels — https://www.pexels.com/api/ (ücretsiz, konuya uygun stok foto)
# PEXELS_API_KEY=
