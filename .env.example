# Canlı site adresi (canonical, Open Graph, sitemap, robots)
NEXT_PUBLIC_SITE_URL=https://meboyunevi.com

# Google Search Console doğrulama (isteğe bağlı)
# GOOGLE_SITE_VERIFICATION=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Google Gemini — https://aistudio.google.com/apikey (ücretsiz kota)
GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.5-flash-lite

# Supabase — blog taslakları ve yayın (Vercel'de dosyaya yazılamaz)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# /admin/blog paneli ve API koruması
ADMIN_PASSWORD=

# Vercel Cron — Authorization: Bearer <CRON_SECRET>
CRON_SECRET=

# true ise haftalık cron taslağı otomatik yayınlar (önerilmez: false)
BLOG_AUTO_PUBLISH=false
