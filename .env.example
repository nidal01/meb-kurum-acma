# Canlı site adresi (canonical, Open Graph, sitemap, robots)
NEXT_PUBLIC_SITE_URL=https://meboyunevi.com

# Google Search Console doğrulama (DNS veya meta)
# GOOGLE_SITE_VERIFICATION=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Google Analytics 4 — Ölçüm Kimliği (G-XXXXXXXXXX)
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# Google Gemini — https://aistudio.google.com/apikey
GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.5-flash-lite

# Supabase — blog taslakları ve yayın
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Admin panel
ADMIN_EMAIL=admin@meboyunevi.com
ADMIN_PASSWORD=
SESSION_SECRET=

# Vercel Cron
CRON_SECRET=
BLOG_AUTO_PUBLISH=false

# --- Otomatik arama motoru indeksleme ---
# IndexNow (Bing/Yandex/Naver/Seznam) — 32+ haneli rastgele bir hex/uuid üretin.
# Doğrulama URL'si otomatik olarak https://meboyunevi.com/api/indexnow/key adresinden
# servis edilir; ayrı bir dosya yerleştirmenize gerek yok.
INDEXNOW_KEY=

# Google Indexing API — service account ile (https://search.google.com/search-console
# içinde Owner olarak eklenmeli). Boş bırakırsanız Google bildirimi atlanır.
GOOGLE_INDEXING_CLIENT_EMAIL=
# PEM formatı; satır sonları için \n karakterlerini olduğu gibi yapıştırın.
GOOGLE_INDEXING_PRIVATE_KEY=

# Blog görselleri (isteğe bağlı)
# BLOG_IMAGE_PROVIDER=auto
# PEXELS_API_KEY=

# --- İletişim formu (Resend) ---
# https://resend.com → API Keys → Domain doğrulama (meboyunevi.com)
RESEND_API_KEY=
CONTACT_TO_EMAIL=info@meboyunevi.com
CONTACT_FROM_EMAIL=MEB Kurum Açma <noreply@meboyunevi.com>

# WhatsApp ön tanımlı mesaj (isteğe bağlı, değiştirebilirsiniz)
NEXT_PUBLIC_WHATSAPP_MESSAGE=Merhaba, MEB kurum açma danışmanlığı hakkında bilgi almak istiyorum.
